## 📦 TypeScript Rules

```ts
// ✅ Correct patterns

// Use interface for object shapes
interface UserProfile {
  id: string
  name: string
  role: 'admin' | 'user' | 'guest'
}

// Use type for unions and computed types
type ApiResponse<T> = {
  data: T | null
  error: string | null
  status: number
}

// Use unknown instead of any
const parseJson = (raw: unknown): Record<string, unknown> => {
  if (typeof raw !== 'object' || raw === null) {
    throw new TypeError('Expected an object')
  }
  return raw as Record<string, unknown>
}

// Always type function return values
export const getFullName = (first: string, last: string): string => {
  return `${first} ${last}`.trim()
}
```

- `strict: true` in `tsconfig.json` — non-negotiable
- Never use `any` — use `unknown` and narrow the type
- Never use non-null assertion `!` — handle nullability explicitly
- Prefer `interface` for object types, `type` for everything else
- Define return types on all exported functions
- Use `satisfies` operator for config objects to get inference + safety
- Keep `types/` for shared global types; co-locate local types with their module

