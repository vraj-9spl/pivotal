## ❌ Patterns That Are Never Acceptable

```ts
// ❌ NEVER — any type
const data: any = await fetch(url)

// ❌ NEVER — default export
export default function MyComponent() {}

// ❌ NEVER — non-null assertion
const user = getUser()!

// ❌ NEVER — logic directly in app/ files (app/ is routing only)
// app/dashboard/page.tsx
export default function Page() {
  const [data, setData] = useState([])           // ❌ state belongs in src/hooks/
  useEffect(() => { fetch('/api/data').then(...) }, []) // ❌ fetch belongs in src/lib/api/
}

// ✅ CORRECT — app/ just wires routing to src/
// app/dashboard/page.tsx
import { DashboardView } from '@/components/dashboard/DashboardView'  // src/components
import { getUser } from '@/lib/api/users'                              // src/lib
export default async function Page() {
  const user = await getUser()
  return <DashboardView user={user} />
}

// ❌ NEVER — unhandled promise
fetchData() // missing await or .catch()

// ❌ NEVER — hardcoded route strings
router.push('/dashboard/settings') // use ROUTES.DASHBOARD.SETTINGS from constants/routes.ts

// ❌ NEVER — swallowed errors
try {
  await riskyOperation()
} catch {
  // silent failure
}
```